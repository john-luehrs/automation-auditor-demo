# ── Server ──────────────────────────────────────────────────────────────────────
PORT=3737

# Set to true to use fixture data from mock/ (no credentials needed).
# Set to false to connect to live systems.
MOCK_MODE=true

# ── GitHub ───────────────────────────────────────────────────────────────────────
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GITHUB_REPO=your-org/your-automation-repo
GITHUB_BRANCH=main
TESTS_BASE_PATH=src/test/java/tests/panels

# ── Zephyr Scale ─────────────────────────────────────────────────────────────────
ZEPHYR_BASE_URL=https://jira.example.com/jira
ZEPHYR_API_KEY=your-zephyr-api-key
ZEPHYR_PROJECT_KEY=EX

# ── Azure OpenAI ─────────────────────────────────────────────────────────────────
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_KEY=your-azure-openai-key
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_ANALYSIS_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# ── OnDemand Portal ───────────────────────────────────────────────────────────────
OD_BASE_URL=https://ondemand.example.com/App
OD_USERNAME=demo-user
OD_PASSWORD=demo-password
